{
  "name": "@telnyx/voice-cloudflare",
  "version": "0.1.0",
  "description": "Telnyx voice providers for the Cloudflare Agents SDK",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./stt": {
      "types": "./dist/stt.d.ts",
      "import": "./dist/stt.js"
    },
    "./tts": {
      "types": "./dist/tts.d.ts",
      "import": "./dist/tts.js"
    },
    "./telephony": {
      "types": "./dist/telephony.d.ts",
      "import": "./dist/telephony.js"
    }
  },
  "scripts": {
    "build": "npx tsc",
    "dev": "npx tsc --watch",
    "check": "npx tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "telnyx",
    "cloudflare",
    "agents",
    "voice",
    "stt",
    "tts",
    "webrtc",
    "sip",
    "telephony"
  ],
  "author": "Telnyx",
  "license": "MIT",
  "peerDependencies": {
    "@cloudflare/voice": ">=0.1.0"
  },
  "devDependencies": {
    "@cloudflare/voice": "^0.1.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/team-telnyx/voice-cloudflare.git"
  },
  "bugs": {
    "url": "https://github.com/team-telnyx/voice-cloudflare/issues"
  },
  "homepage": "https://github.com/team-telnyx/voice-cloudflare#readme",
  "dependencies": {
    "@telnyx/webrtc": "^2.26.2"
  }
}
